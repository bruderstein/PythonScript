:: Edit the path below to your local path for (built) Python2.7 source tree, or set the PYTHONBUILDDIR variable before calling

IF [%PYTHONBUILDDIR%] == [] (
	SET PYTHONBUILDDIR=l:\code\cpython\pcbuild
)
IF [%PYTHONBUILDDIR_X64%] == [] (
	SET PYTHONBUILDDIR_X64=l:\code\cpython\pcbuild_x64
)
IF [%PYTHONBUILDDIR_ARM64%] == [] (
	SET PYTHONBUILDDIR_ARM64=l:\code\cpython\pcbuild_arm64
)